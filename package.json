{
  "name": "effect-htmx",
  "module": "src/server.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:server": "bun run --watch src/server.ts",
    "dev:css": "bunx @tailwindcss/cli -i src/global.css -o dist/styles.css --watch",
    "dev:client": "bun build src/client.ts --outfile dist/client.js --target browser --watch --no-clear-screen",
    "dev": "bun run build && bun run dev:css & bun run dev:client & bun run dev:server",
    "build:css": "bunx @tailwindcss/cli -i src/global.css -o dist/styles.css --minify",
    "build:client": "bun build src/client.ts --outfile dist/client.js --target browser",
    "build": "bun run build:css && bun run build:client",
    "start": "bun run src/server.ts",
    "lint": "bunx biome check src",
    "format": "bunx biome check --write src"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/cli": "^4.2.1",
    "@types/bun": "latest",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/platform": "^0.94.5",
    "@effect/platform-bun": "^0.87.1",
    "@kitajs/html": "^4.2.13",
    "effect": "^3.19.19",
    "htmx.org": "^2.0.8"
  }
}
